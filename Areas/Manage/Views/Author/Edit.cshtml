@model Author

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Edit Author</h1>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Index", "Author")" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <form method="post" action="@Url.Action("Edit", "Author")">
                @Html.AntiForgeryToken()

                <input type="hidden" name="Id" value="@Model.Id" />

                <div class="mb-3">
                    <label for="fullName" class="form-label">Full Name <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="fullName" name="FullName" value="@Model.FullName" placeholder="Enter author full name" required>
                    <span class="text-danger">@Html.ValidationMessageFor(m => m.FullName)</span>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-warning">
                        <i class="bi bi-check-circle"></i> Update Author
                    </button>
                    <a href="@Url.Action("Index", "Author")" class="btn btn-secondary">
                        <i class="bi bi-x-circle"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
@section scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
