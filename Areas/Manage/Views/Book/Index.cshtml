@model List<Book>

@{
    ViewData["Title"] = "Books";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Books Management</h1>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Create", "Book")" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Add New Book
            </a>
        </div>
    </div>

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-info" role="alert">
            <strong>No books found.</strong> Start by adding your first book.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Author</th>
                        <th>Price</th>
                        <th>Discount</th>
                        <th>In Stock</th>
                        <th>Featured</th>
                        <th>New</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var book in Model)
                    {
                        <tr>
                            <td>@book.Id</td>
                            <td>
                                <strong>@book.Name</strong>
                                @if (!string.IsNullOrEmpty(book.MainImageUrl))
                                {
                                    <br />
                                    <small class="text-muted">@book.Desc</small>
                                }
                            </td>
                            <td>
                                @if (book.Author != null)
                                {
                                    <span class="badge bg-secondary">@book.Author.FullName</span>
                                }
                                else
                                {
                                    <span class="text-muted">N/A</span>
                                }
                            </td>
                            <td>
                                <strong>@book.Price.ToString("C")</strong>
                                @if (book.DiscountPercent > 0)
                                {
                                    <br />
                                    <small class="text-danger">-@book.DiscountPercent%</small>
                                }
                            </td>
                            <td>
                                <span class="badge @(book.DiscountPercent > 0 ? "bg-danger" : "bg-success")">
                                    @book.DiscountPercent%
                                </span>
                            </td>
                            <td>
                                @if (book.InStock)
                                {
                                    <span class="badge bg-success">In Stock</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Out of Stock</span>
                                }
                            </td>
                            <td>
                                @if (book.IsFeatured)
                                {
                                    <span class="badge bg-info"><i class="bi bi-star-fill"></i> Featured</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (book.IsNew)
                                {
                                    <span class="badge bg-warning text-dark"><i class="bi bi-lightning-fill"></i> New</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                <a href="@Url.Action("Edit", "Book", new { id = book.Id })" class="btn btn-sm btn-warning">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <a href="@Url.Action("Delete", "Book", new { id = book.Id })" class="btn btn-sm btn-danger deleteBook">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<style>
    .table-responsive {
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
        border-radius: 0.25rem;
    }

    .badge {
        font-size: 0.85rem;
        padding: 0.4rem 0.6rem;
    }

    table td {
        vertical-align: middle;
    }
</style>

@section scripts {
    <script>
        // Delete Book
        $(document).on('click', '.deleteBook', function (e) {
            e.preventDefault();
            const deleteUrl = $(this).attr("href");

            Swal.fire({
                title: "Are you sure?",
                text: "Do you want to delete this book?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#d33",
                cancelButtonColor: "#6c757d",
                confirmButtonText: "Delete",
                cancelButtonText: "Cancel"
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: deleteUrl,
                        type: "get",
                        success: function () {
                            Swal.fire(
                                "Deleted!",
                                "The book has been deleted successfully.",
                                "success"
                            ).then(() => {
                                location.reload();
                            });
                        },
                        error: function () {
                            Swal.fire(
                                "Error!",
                                "An error occurred while deleting the book.",
                                "error"
                            );
                        }
                    });
                }
            });
        });
    </script>
}

