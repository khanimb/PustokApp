@model Author

<div class="row mb-3">
    <div class="col-md-6">
        <p><strong>ID:</strong> @Model.Id</p>
    </div>
    <div class="col-md-6">
        <p><strong>Full Name:</strong> @Model.FullName</p>
    </div>
</div>

<div class="row mb-3">
    <div class="col-12">
        <p><strong>Total Books:</strong> <span class="badge bg-info">@(Model.Books?.Count ?? 0)</span></p>
    </div>
</div>

@if (Model.Books != null && Model.Books.Count > 0)
{
    <div class="mt-4">
        <h6>Books by this Author:</h6>
        <div class="table-responsive">
            <table class="table table-sm table-striped">
                <thead class="table-light">
                    <tr>
                        <th>Title</th>
                        <th>Price</th>
                        <th>Stock</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var book in Model.Books)
                    {
                        <tr>
                            <td>@book.Name</td>
                            <td>@book.Price.ToString("C")</td>
                            <td>
                                <span class="badge @(book.InStock ? "bg-success" : "bg-danger")">
                                    @(book.InStock ? "In Stock" : "Out of Stock")
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="alert alert-info mt-4">No books found by this author yet.</div>
}

