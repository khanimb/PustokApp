@model List<Book>

@foreach(var book in Model)
{
    <div class="single-slide">
        <div class="product-card">
            <div class="product-header">
                <a href="#" class="author">
                    @book.Author?.FullName
                    </a>
                <h3><a href="@Url.Action("Details", "Books", new { id = book.Id })">@book.Name</a></h3>
                </div>
            <div class="product-card--body">
                <div class="card-image">
                    <img src="~/assets/image/products/@book.MainImageUrl" alt="@book.Name">
                    <div class="hover-contents">
                        <a href="@Url.Action("Details", "Books", new { id = book.Id })" class="hover-image">
                            <img src="~/assets/image/products/@book.HoverImageUrl" alt="@book.Name">
                            </a>
                        <div class="hover-btns">
                            <a asp-controller="basket" asp-action="addbasket" asp-route-id="@book.Id" class="single-btn">
                                <i class="fas fa-shopping-basket"></i>
                                </a>
                            <a href="wishlist.html" class="single-btn">
                                <i class="fas fa-heart"></i>
                                </a>
                            <a href="compare.html" class="single-btn">
                                <i class="fas fa-random"></i>
                                </a>
                            <a 
                               asp-controller="books"
                               asp-action="bookmodal"
                               asp-route-id="@book.Id"
                               class="single-btn bookModalIcon">
                                <i class="fas fa-eye"></i>
                            </a>
                            </div>
                        </div>
                    </div>
                <div class="price-block">
                    @if(book.DiscountPercent > 0)
                    {
                        decimal discountedPrice = (decimal)book.Price * (1 - (book.DiscountPercent / 100m));
                        <span class="price">£@discountedPrice.ToString("F2")</span>
                        <del class="price-old">£@book.Price.ToString("F2")</del>
                        <span class="price-discount">@book.DiscountPercent%</span>
                    }
                    else
                    {
                        <span class="price">£@book.Price.ToString("F2")</span>
                    }
                    </div>
                </div>
            </div>
            </div>
}
