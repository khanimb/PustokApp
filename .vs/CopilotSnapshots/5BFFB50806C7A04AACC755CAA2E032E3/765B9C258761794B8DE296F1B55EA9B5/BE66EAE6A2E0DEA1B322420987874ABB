@model Book

@{
    ViewData["Title"] = "Edit Book";
}

<div class="container mt-5">
    <div class="row mb-5">
        <div class="col-lg-8 offset-lg-2">
            <div class="card shadow-lg">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0"><i class="bi bi-pencil-square"></i> Edit Book</h4>
                </div>
                <div class="card-body p-4">
                    <form method="post" action="@Url.Action("Edit", "Book")" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <input type="hidden" name="Id" value="@Model.Id" />

                        <div class="mb-4">
                            <label for="name" class="form-label fw-bold">Book Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control form-control-lg" id="name" name="Name" placeholder="Enter book name" value="@(Model?.Name ?? "")" required>
                        </div>

                        <div class="mb-4">
                            <label for="desc" class="form-label fw-bold">Description</label>
                            <textarea class="form-control form-control-lg" id="desc" name="Desc" rows="3" placeholder="Enter book description">@(Model?.Desc ?? "")</textarea>
                        </div>

                        <div class="mb-4">
                            <label for="authorId" class="form-label fw-bold">Author <span class="text-danger">*</span></label>
                            <select class="form-control form-control-lg" id="authorId" name="AuthorId" required>
                                <option value="">-- Select Author --</option>
                                @if (ViewBag.Authors != null)
                                {
                                    @foreach (var author in ViewBag.Authors)
                                    {
                                        <option value="@author.Id" selected="@(Model?.AuthorId == author.Id ? "selected" : null)">@author.FullName</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label for="price" class="form-label fw-bold">Price <span class="text-danger">*</span></label>
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text">$</span>
                                    <input type="number" class="form-control" id="price" name="Price" placeholder="0.00" value="@(Model?.Price ?? 0)" step="0.01" min="0" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label for="discountPercent" class="form-label fw-bold">Discount %</label>
                                <div class="input-group input-group-lg">
                                    <input type="number" class="form-control" id="discountPercent" name="DiscountPercent" placeholder="0" value="@(Model?.DiscountPercent ?? 0)" min="0" max="100">
                                    <span class="input-group-text">%</span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label for="code" class="form-label fw-bold">Book Code <span class="text-danger">*</span></label>
                            <input type="number" class="form-control form-control-lg" id="code" name="Code" placeholder="Enter book code" value="@(Model?.Code ?? 0)" required>
                        </div>

                        <div class="mb-4">
                            <label for="mainPhoto" class="form-label fw-bold">Main Image</label>
                            <input type="file" class="form-control form-control-lg" id="mainPhoto" name="MainPhoto" accept="image/*" onchange="previewMainImage(this)">
                            <small class="form-text text-muted">Select a JPG, PNG, or JPEG image file (optional)</small>
                            @if (!string.IsNullOrEmpty(Model?.MainImageUrl))
                            {
                                <div class="mt-3">
                                    <p class="fw-bold">Current Main Image:</p>
                                    <img src="~/assets/image/books/@Model.MainImageUrl" alt="@Model.Name" style="max-width: 200px; max-height: 150px; border-radius: 0.25rem;" />
                                </div>
                            }
                            <div id="mainImagePreview" class="mt-3"></div>
                        </div>

                        <div class="mb-4">
                            <label for="hoverPhoto" class="form-label fw-bold">Hover Image</label>
                            <input type="file" class="form-control form-control-lg" id="hoverPhoto" name="HoverPhoto" accept="image/*" onchange="previewHoverImage(this)">
                            <small class="form-text text-muted">Select a JPG, PNG, or JPEG image file (optional)</small>
                            @if (!string.IsNullOrEmpty(Model?.HoverImageUrl))
                            {
                                <div class="mt-3">
                                    <p class="fw-bold">Current Hover Image:</p>
                                    <img src="~/assets/image/books/@Model.HoverImageUrl" alt="@Model.Name" style="max-width: 200px; max-height: 150px; border-radius: 0.25rem;" />
                                </div>
                            }
                            <div id="hoverImagePreview" class="mt-3"></div>
                        </div>

                        
                        <div class="mb-4">
                            <label class="form-label fw-bold">Tags</label>
                            <div class="card border-light">
                                <div class="card-body">
                                    @if (ViewBag.Tags != null && ViewBag.Tags.Count > 0)
                                    {
                                        <div class="row">
                                            @foreach (var tag in ViewBag.Tags)
                                            {
                                                <div class="col-md-6 mb-3">
                                                    <div class="form-check">
                                                        <input class="form-check-input"
                                                               type="checkbox"
                                                               id="tag_@tag.Id"
                                                               name="TagsId"
                                                               value="@tag.Id"
                                                               @(Model?.TagsId?.Contains(tag.Id) == true ? "checked" : "")>
                                                        <label class="form-check-label" for="tag_@tag.Id">
                                                            <span class="badge bg-secondary">@tag.Name</span>
                                                        </label>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <p class="text-muted mb-0">No tags available</p>
                                    }
                                </div>
                            </div>
                            <small class="form-text text-muted">Select one or more tags for this book</small>
                        </div>

                        
                        <div class="row mb-4">
                            <div class="col-md-4">
                                <div class="form-check form-check-lg">
                                    <input class="form-check-input" type="checkbox" id="inStock" name="InStock" @(Model?.InStock == true ? "checked" : "")>
                                    <label class="form-check-label" for="inStock">In Stock</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check form-check-lg">
                                    <input class="form-check-input" type="checkbox" id="isFeatured" name="IsFeatured" @(Model?.IsFeatured == true ? "checked" : "")>
                                    <label class="form-check-label" for="isFeatured">Featured</label>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-check form-check-lg">
                                    <input class="form-check-input" type="checkbox" id="isNew" name="IsNew" @(Model?.IsNew == true ? "checked" : "")>
                                    <label class="form-check-label" for="isNew">New</label>
                                </div>
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-between mt-5">
                            <a href="@Url.Action("Index", "Book")" class="btn btn-outline-secondary btn-lg">
                                <i class="bi bi-arrow-left"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-warning btn-lg">
                                <i class="bi bi-check-circle"></i> Update Book
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="alert alert-info mt-4" role="alert">
                <i class="bi bi-info-circle"></i> <strong>Note:</strong> Fields marked with <span class="text-danger">*</span> are required. Images are optional and will not be changed if not selected.
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        border: none;
        border-top: 4px solid #ffc107;
    }

    .card-header {
        border-bottom: 2px solid #e9ecef;
    }

    .form-label {
        font-size: 1rem;
        margin-bottom: 0.75rem;
        color: #333;
    }

    .form-control-lg {
        padding: 0.875rem 1rem;
        font-size: 1rem;
        border-radius: 0.375rem;
    }

    .form-control:focus, .form-select:focus {
        border-color: #ffc107;
        box-shadow: 0 0 0 0.2rem rgba(255, 193, 7, 0.25);
    }

    .form-check-lg .form-check-input {
        width: 1.25em;
        height: 1.25em;
        margin-top: 0.1em;
    }

    .form-check-lg .form-check-label {
        font-size: 1rem;
        margin-left: 0.5rem;
    }

    .btn-lg {
        padding: 0.75rem 1.5rem;
        font-weight: 500;
    }

    .input-group-text {
        background-color: #e9ecef;
        border: 1px solid #dee2e6;
    }

    small.form-text {
        display: block;
        margin-top: 0.375rem;
    }

    .alert {
        border-radius: 0.375rem;
    }

    #mainImagePreview img, #hoverImagePreview img {
        max-width: 250px;
        max-height: 250px;
        border-radius: 0.375rem;
    }

    .file-name {
        font-size: 0.9rem;
        color: #666;
        margin-top: 0.5rem;
    }
</style>

<script>
    function previewMainImage(input) {
        const preview = document.getElementById('mainImagePreview');
        preview.innerHTML = '';
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function (e) {
                const img = document.createElement('img');
                img.src = e.target.result;
                img.alt = 'Main Image Preview';
                const container = document.createElement('div');
                container.appendChild(img);
                const fileName = document.createElement('div');
                fileName.className = 'file-name';
                fileName.textContent = 'New File: ' + input.files[0].name;
                container.appendChild(fileName);
                preview.appendChild(container);
            };
            reader.readAsDataURL(input.files[0]);
        }
    }

    function previewHoverImage(input) {
        const preview = document.getElementById('hoverImagePreview');
        preview.innerHTML = '';
        if (input.files && input.files[0]) {
            const reader = new FileReader();
            reader.onload = function (e) {
                const img = document.createElement('img');
                img.src = e.target.result;
                img.alt = 'Hover Image Preview';
                const container = document.createElement('div');
                container.appendChild(img);
                const fileName = document.createElement('div');
                fileName.className = 'file-name';
                fileName.textContent = 'New File: ' + input.files[0].name;
                container.appendChild(fileName);
                preview.appendChild(container);
            };
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>
