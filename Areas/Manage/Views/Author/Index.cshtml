@model List<Author>

@{
    ViewData["Title"] = "Authors";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Authors Management</h1>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Create", "Author")" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Add New Author
            </a>
        </div>
    </div>

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-info" role="alert">
            <strong>No authors found.</strong> Start by adding your first author.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Full Name</th>
                        <th>Books Count</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var author in Model)
                    {
                        <tr>
                            <td>@author.Id</td>
                            <td>@author.FullName</td>
                            <td>
                                <span class="badge bg-info">
                                    @(author.Books?.Count ?? 0)
                                </span>
                            </td>
                            <td>
                                <button type="button" class="btn btn-sm btn-info viewAuthorDetails" data-author-id="@author.Id" data-bs-toggle="modal" data-bs-target="#authorDetailsModal">
                                    <i class="bi bi-eye"></i> Details
                                </button>
                                <a href="@Url.Action("Edit", "Author", new { id = author.Id })" class="btn btn-sm btn-warning">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <a href="@Url.Action("Delete", "Author", new { id = author.Id })" class="btn btn-sm btn-danger deleteAuthor">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>


<div class="modal fade" id="authorDetailsModal" tabindex="-1" aria-labelledby="authorDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="authorDetailsModalLabel">Author Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="authorDetailsContent">
                    <div class="text-center">
                        <div class="spinner-border" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <a id="editAuthorBtn" href="#" class="btn btn-warning">
                    <i class="bi bi-pencil"></i> Edit
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .table-responsive {
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
        border-radius: 0.25rem;
    }
</style>
@section scripts {
    <script>
        $(document).on('click', '.viewAuthorDetails', function (e) {
            e.preventDefault();
            const authorId = $(this).attr('data-author-id');

            $.ajax({
                url: '@Url.Action("GetAuthorDetailsPartial", "Author")' + '?id=' + authorId,
                type: 'GET',
                success: function (data) {
                    $('#authorDetailsContent').html(data);
                    $('#editAuthorBtn').attr('href', '@Url.Action("Edit", "Author")' + '?id=' + authorId);
                },
                error: function () {
                    $('#authorDetailsContent').html('<div class="alert alert-danger">Failed to load author details.</div>');
                }
            });
        });

        $(document).on('click', '.deleteAuthor', function (e) {
            e.preventDefault();
            const url = $(this).attr("href");
            Swal.fire({
                title: "Are you sure?",
                text: "Do you want to delete this author?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#d33",
                cancelButtonColor: "#6c757d",
                confirmButtonText: "Delete",
                cancelButtonText: "Cancel"
            }).then((result) => {
                if (result.isConfirmed) {
                    var deleteUrl = $(this).attr("href");
                    $.ajax({
                        url: deleteUrl,
                        type: "get",
                        success: function () {
                            Swal.fire(
                                "Deleted!",
                                "The author has been deleted.",
                                "success"
                            ).then(() => {
                                location.reload();
                            });
                        },
                        error: function () {
                            Swal.fire(
                                "Error!",
                                "An error occurred while deleting the author.",
                                "error"
                            );
                        }
                    });
                }
            });
        });
    </script>
}

